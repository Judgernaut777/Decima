#!/usr/bin/env python3
"""deploy launcher — IDEMPOTENT first-run provisioning.

``decima.services.provision`` deliberately REFUSES to clobber an existing identity: a
second call raises and exits non-zero (this is correct — a restart must never re-mint the
box's root key or overwrite the master seed). But a systemd ``ExecStartPre`` runs on every
boot, so it must be idempotent or the unit fails to start after the first boot.

This wrapper is that idempotency: it provisions ONLY when no identity exists yet, and
exits 0 when one already does. It NEVER re-provisions and NEVER touches an existing seed.
Used by both ``deploy/install.sh`` and the ``decima.service`` ExecStartPre so the
documented install and the running service take the exact same, safe first-run path.

  usage: decima-firstrun <base-dir>
"""
from __future__ import annotations

import os
import sys


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        print("usage: decima-firstrun <base-dir>", file=sys.stderr)
        return 2
    base = argv[0]
    seed_path = os.path.join(base, "keys", "master.seed")
    if os.path.exists(seed_path):
        print(f"decima-firstrun: identity already present at {seed_path} — skipping")
        return 0

    from decima.services.provision import first_run

    summary = first_run(base)
    print(f"decima-firstrun: provisioned {summary['base']} "
          f"(principal {summary['principal'][:16]}…, network={summary['network']})")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
