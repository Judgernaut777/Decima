# Decima
__pycache__/
*.pyc
*.pyo

# the Weft is local truth, not source — it rebuilds from genesis
*.db
weft.db

# never commit signing material (dev master seed)
*.keys

.DS_Store
*.swp
.venv/

# Python build / packaging artifacts (0.3)
build/
dist/
*.egg-info/

# tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.claude/

# node / Playwright (browser qualification, WS1)
node_modules/
# package-lock.json IS tracked: `npm ci` (the CI browser lane) hard-fails without a
# lockfile, and an unpinned @playwright/test range would make the browser gate
# non-reproducible (same reason ruff/mypy are pinned exactly).
/test-results/
/playwright-report/
.playwright/
